{
  "name": "snapmind-expo",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "npm run backend-core:build && node server/index.js",
    "dev": "expo start",
    "expo:start": "expo start",
    "android": "expo run:android",
    "android:start": "expo start --android",
    "backend-core:build:cjs": "tsc -p tsconfig.backend-core.cjs.json",
    "backend-core:build:esm": "tsc -p tsconfig.backend-core.esm.json",
    "backend-core:build": "npm run backend-core:build:cjs && npm run backend-core:build:esm",
    "web": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "build": "npm run backend-core:build && npm run web:build",
    "backend": "npm run backend-core:build && nodemon --watch server --ignore artifacts --ignore src --ignore shared --ignore node_modules server/index.js",
    "backend:start": "npm run backend-core:build && node server/index.js",
    "backend:check": "npm run backend-core:build && node --check server/index.js",
    "ios": "expo run:ios",
    "test": "npm run backend-core:build && node --test server/tests/*.test.js",
    "expo:web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.99.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "hwp.js": "^0.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "officeparser": "^6.0.4",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}
